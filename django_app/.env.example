# =============================================
# HI CONECTA RH — Django
# Copie para .env e configure
# =============================================

DEBUG=True
SECRET_KEY=django-insecure-troque-por-chave-segura-minimo-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados
DATABASE_URL=postgres://postgres:senha@localhost:5432/hiconectarh

# Redis
REDIS_URL=redis://localhost:6379/0

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=seu@email.com
EMAIL_HOST_PASSWORD=senha_app
DEFAULT_FROM_EMAIL=hi Conecta RH <noreply@empresa.com.br>

# JWT
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=7

# Segurança
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
SESSION_COOKIE_AGE=28800

# Uploads
MEDIA_ROOT=media/
MAX_UPLOAD_MB=10

# Empresa (configuração interna)
EMPRESA_NOME=hi Conecta RH
EMPRESA_CNPJ=00.000.000/0001-00
EMPRESA_CIDADE=João Pessoa
EMPRESA_UF=PB

# Integrações (opcional)
BITRIX_WEBHOOK_URL=
ESOCIAL_AMBIENTE=homologacao
CAJU_API_KEY=
