# =============================================
# HI CONECTA RH — VARIÁVEIS DE AMBIENTE
# Copie para .env e preencha com seus dados
# =============================================

# ── APP ──────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_NAME="hi Conecta RH"
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5500

# ── JWT ──────────────────────────────────────
JWT_SECRET=seu_secret_jwt_super_seguro_minimo_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=seu_refresh_secret_diferente_do_jwt
JWT_REFRESH_EXPIRES_IN=7d

# ── BANCO DE DADOS ───────────────────────────
DATABASE_URL="postgresql://postgres:senha@localhost:5432/hiconectarh?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── REDIS ────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── EMAIL (SMTP) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_app
EMAIL_FROM="hi Conecta RH <noreply@hiconectarh.com.br>"

# ── ARMAZENAMENTO ────────────────────────────
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE=10485760
# Para S3/R2 (produção)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=

# ── LOGS ─────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=logs

# ── RATE LIMIT ───────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ── SEGURANÇA ────────────────────────────────
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:5500,http://localhost:3000

# ── ESOCIAL (futuro) ─────────────────────────
ESOCIAL_AMBIENTE=homologacao
ESOCIAL_CERT_PATH=
ESOCIAL_CERT_PASS=

# ── BITRIX24 (opcional) ──────────────────────
BITRIX_WEBHOOK_URL=

# ── WHATSAPP (opcional) ──────────────────────
WAPI_URL=
WAPI_TOKEN=

# ── BULL DASHBOARD ───────────────────────────
BULL_BOARD_USER=admin
BULL_BOARD_PASS=troque_esta_senha_forte
