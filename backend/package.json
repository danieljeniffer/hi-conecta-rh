{
  "name": "hi-conecta-rh-backend",
  "version": "1.0.0",
  "description": "Backend Enterprise SaaS — hi Conecta RH",
  "main": "src/server.js",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "dev":         "nodemon src/server.js",
    "start":       "node src/server.js",
    "build":       "echo 'No build step required'",
    "db:migrate":  "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "db:seed":     "node prisma/seed.js",
    "db:studio":   "npx prisma studio",
    "db:reset":    "npx prisma migrate reset --force && node prisma/seed.js",
    "lint":        "eslint src/ --fix",
    "test":        "jest --coverage",
    "test:watch":  "jest --watchAll",
    "docker:up":   "docker-compose up -d",
    "docker:down": "docker-compose down",
    "logs":        "pm2 logs hi-conecta-rh",
    "pm2:start":   "pm2 start ecosystem.config.js",
    "pm2:stop":    "pm2 stop hi-conecta-rh"
  },
  "dependencies": {
    "@prisma/client":    "^5.14.0",
    "bcrypt":            "^5.1.1",
    "bull":              "^4.12.9",
    "bullmq":            "^5.8.0",
    "compression":       "^1.7.4",
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.5",
    "express":           "^4.19.2",
    "express-rate-limit":"^7.3.1",
    "express-validator": "^7.1.0",
    "helmet":            "^7.1.0",
    "ioredis":           "^5.4.1",
    "jsonwebtoken":      "^9.0.2",
    "morgan":            "^1.10.0",
    "multer":            "^1.4.5-lts.1",
    "nodemailer":        "^6.9.14",
    "socket.io":         "^4.7.5",
    "uuid":              "^10.0.0",
    "winston":           "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod":               "^3.23.8",
    "pdf-lib":           "^1.17.1",
    "sharp":             "^0.33.4",
    "dayjs":             "^1.11.11",
    "slugify":           "^1.6.6",
    "xss":               "^1.0.15"
  },
  "devDependencies": {
    "eslint":            "^9.4.0",
    "jest":              "^29.7.0",
    "nodemon":           "^3.1.4",
    "prisma":            "^5.14.0",
    "supertest":         "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":       ["**/__tests__/**/*.test.js"]
  }
}
