# Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dp_hiconecta
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# JWT
JWT_SECRET=seu_jwt_secret_muito_seguro_aqui
JWT_EXPIRES_IN=8h

# CORS
FRONTEND_URL=http://localhost:3000

# E-mail (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_app

# Upload de documentos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Empresa (padrão para documentos)
EMPRESA_NOME=hi Conecta RH
EMPRESA_CNPJ=00.000.000/0001-00
EMPRESA_ENDERECO=Rua Exemplo, 123 - São Paulo/SP

# eSocial (ambiente de testes)
ESOCIAL_AMBIENTE=2
ESOCIAL_VERSAO_LAYOUT=S-1.2

# Bitrix24 (integração futura)
BITRIX_WEBHOOK_URL=
BITRIX_PORTAL_URL=
